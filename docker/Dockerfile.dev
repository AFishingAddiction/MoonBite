FROM mcr.microsoft.com/devcontainers/javascript-node:24

RUN mkdir -p /app && chown node:node /app
WORKDIR /app

RUN apt-get update && apt-get install -y \
    chromium \
    firefox-esr \
    jq \
    less \
    most \
    xvfb \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

ENV CHROME_BIN=/usr/bin/chromium
ENV FIREFOX_BIN=/usr/bin/firefox-esr

RUN mkdir -p /commandhistory \
    && touch /commandhistory/.bash_history \
    && chown -R node.node /commandhistory \
    && echo "export HISTFILE=/commandhistory/.bash_history" >> "/home/node/.bashrc" \
    && echo "shopt -s histappend" >> "/home/node/.bashrc" \
    && echo "PROMPT_COMMAND='history -a'" >> "/home/node/.bashrc"

USER node

RUN curl -fsSL https://claude.ai/install.sh | bash && \
    curl -fsSL https://bun.sh/install | bash && \
    /home/node/.local/bin/claude plugin marketplace add mksglu/context-mode && \
    /home/node/.local/bin/claude plugin install context-mode@context-mode

COPY --chown=node:node docker/install-volt-agents.sh /tmp/install-volt-agents.sh
RUN bash /tmp/install-volt-agents.sh && rm /tmp/install-volt-agents.sh

COPY --chown=node:node package*.json ./

RUN npm install
RUN npx playwright install --with-deps chromium

EXPOSE 4202

CMD ["sleep", "infinity"]

{
  "name": "MoonBite",
  "build": {
    "dockerfile": "../docker/Dockerfile.dev",
    "context": ".."
  },
  "remoteUser": "node",
  "postCreateCommand": "npm install && bash ~/install-volt-agents.sh",
  "mounts": [
    "source=angular-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=angular-claude-config-${devcontainerId},target=/home/node/.claude,type=volume"
  ],
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/node/.local/bin"
  },
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "angular.ng-template",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "ms-playwright.playwright",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "editor.rulers": [100],
        "js/ts.preferences.importModuleSpecifier": "relative"
      }
    }
  },
  "forwardPorts": [4202],
  "portsAttributes": {
    "4202": {
      "label": "Angular Dev Server",
      "onAutoForward": "notify"
    }
  }
}
